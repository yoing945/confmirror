# Git配置备份工具 .gitignore

# === Python ===
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# pipenv
Pipfile.lock

# poetry
poetry.lock

# pdm
.pdm.toml

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# PyCharm
.idea/

# VS Code
.vscode/
*.code-workspace

# === 系统和工具 ===
# 操作系统生成的文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~
.#*

# 备份文件
*.bak
*.backup
*.old
*.orig

# 编辑器文件
*.sublime-project
*.sublime-workspace

# === 项目特定 ===
# 实际的备份内容（通常应该提交，但某些情况下可能需要忽略）
# backup/
# 如果你不想提交备份的配置文件，可以取消下面这行
# sync.conf

# 日志文件
logs/
*.log
log-*.log
log-backup.log

# 运行时生成的文件
*.pid

# 测试文件
test-logs/
# 保留 tests/ 目录提交到仓库，用于 CI
test-manual/

example*/

# 配置文件（敏感信息）
config.local.*
secrets.*
credentials.*

# === Git相关 ===
# Git配置（通常应该忽略）
.gitconfig.local
.gitignore.local

# === AI 助手规划文档 ===
# 本地设计/计划文档，不纳入版本控制
docs/superpowers/

# === 其他 ===
# 大文件
*.tar.gz
*.zip
*.rar
*.7z

# 编译后的二进制文件
*.exe
*.out
*.app

# 数据库文件
*.db
*.sqlite

# 密钥和证书
*.key
*.pem
*.crt
*.p12

# 环境变量文件
.env.local
.env.development
.env.test
.env.production

# Git配置备份工具 - 环境配置文件
# 复制此文件为 .env 并根据实际情况修改配置

# 目标备份配置文件路径（JSON格式）
BACKUP_CONFIG_FILE=./sync.conf

# 镜像备份根目录路径（Git仓库）
GIT_BACKUP_ROOT=./backup

# 脚本备份根目录路径
GIT_BACKUP_SCRIPT_ROOT=./backup-script

# 日志文件路径
LOG_FILE=./log-backup.log

# 日志保留行数
LOG_KEEP_LINES=100

# Git仓库远程地址（可选，用于自动推送）
GIT_REMOTE_URL=

# Git分支名称
GIT_BRANCH=main

# 备份时是否自动提交到Git（true/false）
AUTO_GIT_COMMIT=false

# 备份时是否自动推送到远程（true/false）
AUTO_GIT_PUSH=false

# 是否显示详细输出（true/false）
VERBOSE=true

# 备份时排除的文件/目录模式（逗号分隔）
EXCLUDE_PATTERNS=.git,*.log,*.tmp,cache,temp,*.pid,*.bak,downloads,__pycache__,node_modules

# 是否启用备份前文件校验（true/false）
ENABLE_FILE_CHECKSUM=false